# Local proof-of-concept settings
APP_BASE_URL=http://127.0.0.1:3838

APP_HOST=127.0.0.1
APP_PORT=3838

# Database backend.
# Leave DATABASE_BACKEND unset or set to sqlite for local proof-of-concept use.
DATABASE_BACKEND=sqlite
SQLITE_DB_PATH=data/app.sqlite

# Optional hosted MongoDB Atlas backend for live pilot deployments.
# Store the real URI only in your local .Renviron or deployment secret settings.
# Do not commit the connection string because it contains database credentials.
# DATABASE_BACKEND=mongodb
# MONGODB_URI=mongodb+srv://<user>:<password>@<cluster-host>/?retryWrites=true&w=majority
# MONGODB_DATABASE=meeting_poll

# Optional legacy/dev fallback.
# If set, ?create=<this-value> opens the old standalone create-poll route.
# The normal organizer workflow starts at / and uses email-code login.
POLL_CREATION_SECRET=replace-with-a-private-random-value

# Organizer portal email-code login.
# Main owner email controls who can approve secondary organizer access.
APP_MAIN_OWNER_EMAIL=owner@example.org

# Set ORGANIZER_AUTH_SECRET to a long random value. It is used to hash login codes.
ORGANIZER_AUTH_SECRET=replace-with-a-different-private-random-value

# SMTP settings for sending organizer login codes.
# Leave blank for local development unless you have an SMTP account.
SMTP_HOST=
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_SSL=false

# Local development only: if true and SMTP is not configured, the login code is shown on screen.
# Do not enable this on public deployments.
ALLOW_DEV_AUTH_CODE_DISPLAY=false
